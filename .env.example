# ═══════════════════════════════════════
#  CHARLOTECH — Environment Variables
#  Copy this to .env and fill in values
# ═══════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=charlotech

# JWT Secrets (use long random strings in production!)
JWT_SECRET=charlotech_jwt_secret_change_this_in_production_2026
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=charlotech_admin_secret_change_this_in_production_2026
ADMIN_JWT_EXPIRES_IN=8h

# Email (Nodemailer — use Gmail App Password or SMTP service)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=info@charlotech.co.za
MAIL_PASS=your_app_password_here
MAIL_FROM="CharloTech <info@charlotech.co.za>"

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000
